<%- include("../partials/header") %>
<% const supplierData = locals.supplier || null; %>
<% const ingredientsList = locals.ingredients || []; %>
<% const linked = locals.linkedIngredients || []; %>
<% const phone = locals.phoneData || { country_code: '+52', number: '' }; %>
<% const selectedCode = phone.country_code || '+52'; %>

<h3><%= title %></h3>

<div class="card" style="max-width: 800px;">
  <div class="card-body">
    <form method="POST" action="<%= supplierData ? `/admin/proveedores/${supplierData.id}/editar` : '/admin/proveedores' %>" id="supplierForm">
      <div class="mb-3">
        <label class="form-label">Nombre *</label>
        <input type="text" class="form-control" name="name" value="<%= supplierData ? supplierData.name : '' %>" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Contacto (Persona)</label>
        <input type="text" class="form-control" name="contact_info" value="<%= supplierData && supplierData.contact_info ? supplierData.contact_info : '' %>" placeholder="Ej: Juan García" />
      </div>

      <div class="mb-3">
        <label class="form-label">Teléfono Internacional</label>
        <div class="input-group">
          <select id="countryCode" class="form-select" style="max-width: 180px;" name="country_code">
            <option value="+52" <%= selectedCode === '+52' ? 'selected' : '' %>>🇲🇽 México (+52)</option>
            <option value="+34" <%= selectedCode === '+34' ? 'selected' : '' %>>🇪🇸 España (+34)</option>
            <option value="+1" <%= selectedCode === '+1' ? 'selected' : '' %>>🇺🇸 USA/Canadá (+1)</option>
            <option value="+55" <%= selectedCode === '+55' ? 'selected' : '' %>>🇧🇷 Brasil (+55)</option>
            <option value="+54" <%= selectedCode === '+54' ? 'selected' : '' %>>🇦🇷 Argentina (+54)</option>
            <option value="+56" <%= selectedCode === '+56' ? 'selected' : '' %>>🇨🇱 Chile (+56)</option>
            <option value="+57" <%= selectedCode === '+57' ? 'selected' : '' %>>🇨🇴 Colombia (+57)</option>
            <option value="+51" <%= selectedCode === '+51' ? 'selected' : '' %>>🇵🇪 Perú (+51)</option>
            <option value="+502" <%= selectedCode === '+502' ? 'selected' : '' %>>🇬🇹 Guatemala (+502)</option>
            <option value="+44" <%= selectedCode === '+44' ? 'selected' : '' %>>🇬🇧 UK (+44)</option>
            <option value="+33" <%= selectedCode === '+33' ? 'selected' : '' %>>🇫🇷 Francia (+33)</option>
            <option value="+49" <%= selectedCode === '+49' ? 'selected' : '' %>>🇩🇪 Alemania (+49)</option>
            <option value="+39" <%= selectedCode === '+39' ? 'selected' : '' %>>🇮🇹 Italia (+39)</option>
            <option value="+61" <%= selectedCode === '+61' ? 'selected' : '' %>>🇦🇺 Australia (+61)</option>
            <option value="+81" <%= selectedCode === '+81' ? 'selected' : '' %>>🇯🇵 Japón (+81)</option>
          </select>
          <input
            type="tel"
            id="phoneNumber"
            class="form-control"
            name="phone"
            value="<%= phone.number || '' %>"
            placeholder="Ej: 5551234567"
            inputmode="numeric"
          />
        </div>
        <small class="form-text text-muted" id="phoneHint">Ingresa solo el número (sin el código de país)</small>
      </div>

      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" class="form-control" name="email" value="<%= supplierData && supplierData.email ? supplierData.email : '' %>" placeholder="Ej: contacto@proveedor.com" />
      </div>

      <div class="mb-3">
        <label class="form-label">Ingredientes que suministra</label>
        <div id="supplierIngredientsContainer" data-ingredient-exclusion>
          <% if (linked.length > 0) { %>
            <% linked.forEach(function(link) { %>
              <div class="d-flex gap-2 mb-2 align-items-end supplier-ingredient-row">
                <select class="form-select mutual-ingredient-select" name="supplier_ingredients[]">
                  <option value="">-- Selecciona un ingrediente --</option>
                  <% ingredientsList.forEach(function(ing) { %>
                    <option value="<%= ing.id %>" <%= link.ingredient_id === ing.id ? 'selected' : '' %>><%= ing.name %></option>
                  <% }) %>
                </select>
                <input type="number" placeholder="Costo unitario" name="supplier_costs[]" class="form-control" style="max-width: 150px;" step="0.01" min="0" value="<%= link.unit_cost || 0 %>" />
                <button type="button" class="btn btn-sm btn-danger" data-remove-ingredient-row>Quitar</button>
              </div>
            <% }) %>
          <% } %>
        </div>
        <button type="button" id="addIngredientBtn" class="btn btn-sm btn-success mt-2">+ Agregar ingrediente</button>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          <%= supplierData ? 'Actualizar Proveedor' : 'Crear Proveedor' %>
        </button>
        <a href="/admin/proveedores" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
const supplierIngredientsList = <%- JSON.stringify(ingredientsList.map(function(ing) { return { id: ing.id, name: ing.name }; })) %>;
let supplierIngredientExclusion = null;

const phoneRules = {
  '+52': { maxLength: 10, pattern: '^\\d{10}$', name: 'México' },
  '+34': { maxLength: 9, pattern: '^\\d{9}$', name: 'España' },
  '+1': { maxLength: 10, pattern: '^\\d{10}$', name: 'USA/Canadá' },
  '+55': { maxLength: 11, pattern: '^\\d{9,11}$', name: 'Brasil' },
  '+54': { maxLength: 10, pattern: '^\\d{9,10}$', name: 'Argentina' },
  '+56': { maxLength: 9, pattern: '^\\d{9}$', name: 'Chile' },
  '+57': { maxLength: 10, pattern: '^\\d{10}$', name: 'Colombia' },
  '+51': { maxLength: 9, pattern: '^\\d{9}$', name: 'Perú' },
  '+502': { maxLength: 8, pattern: '^\\d{8}$', name: 'Guatemala' },
  '+44': { maxLength: 10, pattern: '^\\d{10}$', name: 'UK' },
  '+33': { maxLength: 9, pattern: '^\\d{9}$', name: 'Francia' },
  '+49': { maxLength: 11, pattern: '^\\d{10,11}$', name: 'Alemania' },
  '+39': { maxLength: 10, pattern: '^\\d{9,10}$', name: 'Italia' },
  '+61': { maxLength: 9, pattern: '^\\d{9}$', name: 'Australia' },
  '+81': { maxLength: 10, pattern: '^\\d{10}$', name: 'Japón' },
};

const countrySelect = document.getElementById('countryCode');
const phoneInput = document.getElementById('phoneNumber');
const phoneHint = document.getElementById('phoneHint');
function buildSupplierIngredientOptions(selectedId) {
  let html = '<option value="">-- Selecciona un ingrediente --</option>';
  supplierIngredientsList.forEach((ing) => {
    const selected = String(ing.id) === String(selectedId) ? 'selected' : '';
    html += `<option value="${ing.id}" ${selected}>${ing.name}</option>`;
  });
  return html;
}

function updatePhoneValidation() {
  const rules = phoneRules[countrySelect.value];
  if (!rules) return;
  phoneInput.maxLength = rules.maxLength;
  phoneInput.pattern = rules.pattern;
  phoneInput.placeholder = `Ej: ${rules.maxLength} dígitos (${rules.name})`;
  phoneHint.textContent = `Formato para ${rules.name}: ${rules.maxLength} dígitos numéricos`;
}

countrySelect.addEventListener('change', updatePhoneValidation);
phoneInput.addEventListener('input', (e) => {
  e.target.value = e.target.value.replace(/\D/g, '').slice(0, e.target.maxLength);
});

document.getElementById('supplierForm').addEventListener('submit', (e) => {
  const number = phoneInput.value.trim();
  if (!number) return;
  const rules = phoneRules[countrySelect.value];
  if (rules && !new RegExp(rules.pattern).test(number)) {
    e.preventDefault();
    alert(`Teléfono inválido para ${rules.name}. Debe cumplir el formato de ${rules.maxLength} dígitos.`);
  }
});

function addSupplierIngredientRow(selectedId) {
  const container = document.getElementById('supplierIngredientsContainer');
  if (!supplierIngredientsList.length) {
    alert('No hay ingredientes registrados en el inventario.');
    return;
  }

  const row = document.createElement('div');
  row.className = 'd-flex gap-2 mb-2 align-items-end supplier-ingredient-row';
  row.setAttribute('data-ingredient-row', '');
  row.innerHTML = `
    <select class="form-select mutual-ingredient-select" name="supplier_ingredients[]">
      ${buildSupplierIngredientOptions(selectedId || '')}
    </select>
    <input type="number" placeholder="Costo unitario" name="supplier_costs[]" class="form-control" style="max-width: 150px;" step="0.01" min="0" value="0" />
    <button type="button" class="btn btn-sm btn-danger" data-remove-ingredient-row>Quitar</button>
  `;
  container.appendChild(row);
  if (supplierIngredientExclusion) supplierIngredientExclusion.sync();
}

const supplierIngredientsContainer = document.getElementById('supplierIngredientsContainer');
supplierIngredientsContainer
  .querySelectorAll('.supplier-ingredient-row')
  .forEach((row) => row.setAttribute('data-ingredient-row', ''));

document.getElementById('addIngredientBtn').addEventListener('click', () => addSupplierIngredientRow());

if (supplierIngredientsContainer && window.IngredientExclusion) {
  supplierIngredientExclusion = IngredientExclusion.init(
    supplierIngredientsContainer,
    '.mutual-ingredient-select'
  );
}

if (!supplierIngredientsContainer.querySelector('.supplier-ingredient-row') && supplierIngredientsList.length) {
  addSupplierIngredientRow();
}

updatePhoneValidation();
</script>

<%- include("../partials/footer") %>
