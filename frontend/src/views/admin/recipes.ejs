<%- include("../partials/header") %>
<%- include("../partials/menu") %>

<h3>Recetario</h3>

<div class="alert alert-info">
  <strong>Instrucciones:</strong> Haz clic en un platillo para editar su receta (ingredientes requeridos).
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>Platillo</th>
        <th>Precio</th>
        <th>Ingredientes</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (menuItems && menuItems.length > 0) { %>
        <% menuItems.forEach(item => { %>
          <tr>
            <td><strong><%= item.name %></strong></td>
            <td>$<%= item.price.toFixed(2) %></td>
            <td><span class="badge bg-info"><%= item.total_ingredients %></span></td>
            <td>
              <a href="/admin/recetas/<%= item.id %>" class="btn btn-sm btn-info">
                Editar Receta
              </a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="4" class="text-center">No hay platillos. Crea uno primero en <a href="/admin/menu">Menú de Platillos</a>.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/footer") %>
