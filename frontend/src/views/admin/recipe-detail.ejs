<%- include("../partials/header") %>
<%- include("../partials/menu") %>

<h3><%= menuItem.name %></h3>
<p class="text-muted"><%= menuItem.description %></p>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <strong>Ingredientes Actuales</strong>
      </div>
      <div class="card-body">
        <% if (ingredients && ingredients.length > 0) { %>
          <table class="table table-sm">
            <thead>
              <tr>
                <th>Ingrediente</th>
                <th>Cantidad</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody>
              <% ingredients.forEach(ing => { %>
                <tr>
                  <td><%= ing.name %></td>
                  <td><%= ing.quantity_required %> <%= ing.base_unit %></td>
                  <td>
                    <form method="POST" action="/admin/recetas/<%= menuItem.id %>/quitar-ingrediente/<%= ing.recipe_ingredient_id %>" style="display:inline;" class="needs-confirm">
                      <button type="submit" class="btn btn-sm btn-danger" data-confirm="¿Quitar este ingrediente?">Quitar</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p class="text-muted">Sin ingredientes asignados.</p>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-success text-white">
        <strong>Agregar Ingrediente</strong>
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/recetas/<%= menuItem.id %>/agregar-ingrediente">
          <div class="mb-3">
            <label class="form-label">Ingrediente</label>
            <select class="form-select" name="ingredient_id" required>
              <option value="">Selecciona un ingrediente...</option>
              <% allIngredients.forEach(ing => { %>
                <option value="<%= ing.id %>"><%= ing.name %> (<%= ing.base_unit %>)</option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Cantidad Requerida</label>
            <div class="input-group">
              <input type="number" step="0.01" name="quantity_required" class="form-control" placeholder="0.00" required />
              <span class="input-group-text" id="unit-display">unidad</span>
            </div>
            <small class="form-text text-muted">Ingresa en la unidad base del ingrediente (g, ml, pcs)</small>
          </div>

          <button class="btn btn-success w-100" type="submit">Agregar a Receta</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  <a href="/admin/recetas" class="btn btn-secondary">Volver al Recetario</a>
</div>

<script>
  document.querySelector('select[name="ingredient_id"]').addEventListener('change', function() {
    const selected = this.options[this.selectedIndex];
    const text = selected.textContent;
    const unitMatch = text.match(/\(([a-z]+)\)$/);
    const unit = unitMatch ? unitMatch[1] : 'unidad';
    document.getElementById('unit-display').textContent = unit;
  });
</script>

<%- include("../partials/footer") %>
