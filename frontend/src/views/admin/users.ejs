<%- include("../partials/header") %>
<%- include("../partials/menu") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Usuarios</h3>
  <a class="btn btn-primary" href="/registro">Registrar usuario</a>
</div>
<table class="table table-bordered">
  <thead><tr><th>Nombre</th><th>Correo</th><th>Rol</th><th>Creado</th></tr></thead>
  <tbody>
    <% users.forEach((u) => { %>
    <tr>
      <td><%= u.name %></td>
      <td><%= u.email %></td>
      <td>
        <form action="/admin/usuarios/<%= u.id %>/rol" method="POST" class="d-flex gap-2">
          <select class="form-select form-select-sm" name="role">
            <option value="admin" <%= u.role === "admin" ? "selected" : "" %>>admin</option>
            <option value="empleado" <%= u.role === "empleado" ? "selected" : "" %>>empleado</option>
          </select>
          <button class="btn btn-sm btn-warning">Guardar</button>
        </form>
      </td>
      <td><%= new Date(u.created_at).toLocaleString("es-MX") %></td>
    </tr>
    <% }) %>
  </tbody>
</table>
<%- include("../partials/footer") %>
