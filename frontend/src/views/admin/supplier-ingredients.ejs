<%- include("../partials/header") %>
<div class="mb-3">
  <h3><%= supplier.name %></h3>
  <p class="text-muted">
    <% if (supplier.email) { %>Email: <a href="mailto:<%= supplier.email %>"><%= supplier.email %></a><br /><% } %>
    <% if (supplier.phone) { %>Teléfono: <a href="tel:<%= supplier.phone %>"><%= supplier.phone %></a><br /><% } %>
    <% if (supplier.contact_info) { %>Contacto: <%= supplier.contact_info %><br /><% } %>
  </p>
  <a href="/admin/proveedores" class="btn btn-secondary btn-sm">← Volver a Proveedores</a>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Ingredientes Vinculados</h5>
      </div>
      <div class="card-body">
        <% if (linkedIngredients && linkedIngredients.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Ingrediente</th>
                  <th>Costo Unitario</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% linkedIngredients.forEach(item => { %>
                  <tr>
                    <td><%= item.name %></td>
                    <td>
                      <form method="POST" action="/admin/proveedores/<%= supplier.id %>/actualizar-costo/<%= item.link_id %>" class="d-flex gap-2">
                        <input type="number" step="0.01" name="unit_cost" value="<%= item.unit_cost || 0 %>" class="form-control form-control-sm" style="max-width: 80px;" />
                        <button type="submit" class="btn btn-sm btn-success">Guardar</button>
                      </form>
                    </td>
                    <td>
                      <form method="POST" action="/admin/proveedores/<%= supplier.id %>/quitar-ingrediente/<%= item.link_id %>" style="display: inline;" onsubmit="return confirm('¿Remover este ingrediente?');">
                        <button type="submit" class="btn btn-sm btn-danger">Remover</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-muted">Sin ingredientes vinculados aún.</p>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Agregar Ingredientes</h5>
      </div>
      <div class="card-body">
        <% if (allIngredients && allIngredients.length > 0) { %>
          <form method="POST" action="/admin/proveedores/<%= supplier.id %>/agregar-ingrediente">
            <div class="mb-3">
              <label class="form-label">Ingrediente *</label>
              <select name="ingredient_id" class="form-select" required>
                <option value="">Selecciona un ingrediente...</option>
                <% allIngredients.forEach(ing => { %>
                  <option value="<%= ing.id %>"><%= ing.name %> (<%= ing.base_unit %>)</option>
                <% }) %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Costo Unitario</label>
              <input type="number" step="0.01" name="unit_cost" class="form-control" placeholder="0.00" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Agregar Ingrediente</button>
          </form>
        <% } else { %>
          <p class="text-muted">Todos los ingredientes ya están vinculados a este proveedor.</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>
