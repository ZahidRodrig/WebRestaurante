<%- include("../partials/header") %>
<h3>Categorias</h3>
<div class="row">
  <div class="col-md-5">
    <div class="card mb-3">
      <div class="card-body">
        <h5>Nueva categoria</h5>
        <form method="POST" action="/admin/categorias">
          <input class="form-control mb-2" name="name" placeholder="Nombre" required />
          <button class="btn btn-primary">Guardar</button>
        </form>
      </div>
    </div>
  </div>
</div>
<table class="table table-bordered">
  <thead><tr><th>Nombre</th><th>Ingredientes</th><th>Ver ingredientes</th><th>Acciones</th></tr></thead>
  <tbody>
    <% categories.forEach((c) => { %>
    <tr>
      <td>
        <form action="/admin/categorias/<%= c.id %>/editar" method="POST" class="d-flex gap-2 auto-submit-form">
          <input class="form-control form-control-sm auto-submit-input" name="name" value="<%= c.name %>" required />
        </form>
      </td>
      <td><%= c.ingredients_count %></td>
      <td>
        <a href="/admin/ingredientes?category=<%= c.id %>" class="btn btn-sm btn-info">Ver ingredientes</a>
      </td>
      <td>
        <form action="/admin/categorias/<%= c.id %>/eliminar" method="POST">
          <button class="btn btn-sm btn-danger">Eliminar</button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
<%- include("../partials/footer") %>
