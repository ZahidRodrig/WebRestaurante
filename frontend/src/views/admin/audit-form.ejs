<%- include("../partials/header") %>
<%- include("../partials/menu") %>

<h3>Nueva Auditoría de Inventario</h3>

<div class="card" style="max-width: 600px;">
  <div class="card-body">
    <form method="POST" action="/admin/auditoria">
      <div class="mb-3">
        <label class="form-label">Ingrediente</label>
        <select class="form-select" name="ingredient_id" id="ingredient_select" required>
          <option value="">Selecciona un ingrediente...</option>
          <% ingredients.forEach(ing => { %>
            <option value="<%= ing.id %>" data-theoretical="<%= ing.stock_theoretical %>" data-physical="<%= ing.stock_physical %>" data-baseunit="<%= ing.base_unit %>">
              <%= ing.name %> (<%= ing.base_unit %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="row">
        <div class="col-md-6">
          <div class="alert alert-info">
            <small><strong>Stock Teórico:</strong></small>
            <p id="theoretical-stock">-</p>
          </div>
        </div>
        <div class="col-md-6">
          <div class="alert alert-warning">
            <small><strong>Stock Físico Anterior:</strong></small>
            <p id="previous-physical">-</p>
          </div>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Stock Físico Nuevo (Conteo Manual)</label>
        <div class="input-group">
          <input class="form-control" type="number" step="0.01" name="new_physical_stock" id="new_physical_stock" required />
          <span class="input-group-text" id="unit-label">unidad</span>
        </div>
        <small class="form-text text-muted">Ingresa en la unidad base del ingrediente</small>
      </div>

      <div id="variance-display" class="alert alert-secondary" style="display:none;">
        <strong>Varianza Estimada:</strong> <span id="variance-value">0</span>
      </div>

      <button class="btn btn-primary w-100" type="submit">Registrar Auditoría</button>
      <a href="/admin/auditoria" class="btn btn-secondary w-100 mt-2">Cancelar</a>
    </form>
  </div>
</div>

<script>
  const ingredientSelect = document.getElementById('ingredient_select');
  const theoreticalDisplay = document.getElementById('theoretical-stock');
  const previousPhysicalDisplay = document.getElementById('previous-physical');
  const newPhysicalInput = document.querySelector('input[name="new_physical_stock"]');
  const unitLabel = document.getElementById('unit-label');
  const varianceDisplay = document.getElementById('variance-display');
  const varianceValue = document.getElementById('variance-value');

  function formatStock(value, unit) {
    return value !== 'null' && value !== undefined && value !== null
      ? `${value} ${unit}`
      : '-';
  }

  ingredientSelect.addEventListener('change', function() {
    const selected = this.options[this.selectedIndex];
    const theoretical = selected.dataset.theoretical;
    const physical = selected.dataset.physical;
    const baseUnit = selected.dataset.baseunit || 'unidad';

    theoreticalDisplay.textContent = formatStock(theoretical, baseUnit);
    previousPhysicalDisplay.textContent = formatStock(physical, baseUnit);
    unitLabel.textContent = baseUnit;
    newPhysicalInput.value = '';
    varianceDisplay.style.display = 'none';
  });

  newPhysicalInput.addEventListener('input', function() {
    const selected = ingredientSelect.options[ingredientSelect.selectedIndex];
    if (!selected.value) return;

    const physical = parseFloat(selected.dataset.physical);
    const newValue = parseFloat(this.value);

    if (!isNaN(physical) && !isNaN(newValue)) {
      const variance = newValue - physical;
      varianceValue.textContent = variance >= 0 ? '+' + variance.toFixed(2) : variance.toFixed(2);
      varianceDisplay.style.display = 'block';
      varianceDisplay.className = 'alert ' + (variance >= 0 ? 'alert-success' : 'alert-danger');
    }
  });
</script>

<%- include("../partials/footer") %>
