<%- include("../partials/header") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Ingredientes</h3>
  <div class="d-flex gap-2 align-items-center">
    <a href="/admin/ingredientes/nuevo" class="btn btn-primary">Nuevo ingrediente</a>
    <select id="unit-system-select" class="form-select form-select-sm">
      <option value="metric">Métrico</option>
      <option value="imperial">Imperial</option>
    </select>
  </div>
</div>
<form class="row g-2 mb-3" method="GET">
  <div class="col-md-5">
    <input class="form-control" name="search" value="<%= filters.search %>" placeholder="Buscar ingrediente" />
  </div>
  <div class="col-md-4">
    <select class="form-select" name="category">
      <option value="">Todas las categorias</option>
      <% categories.forEach((c) => { %>
      <option value="<%= c.id %>" <%= String(filters.category) === String(c.id) ? "selected" : "" %>><%= c.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3"><button class="btn btn-outline-secondary w-100">Filtrar</button></div>
</form>
<div class="table-responsive">
  <table class="table table-bordered table-hover">
    <thead><tr><th>Nombre</th><th>Categoria</th><th>Stock</th><th>Minimo</th><th>Mov.</th><th>Acciones</th></tr></thead>
    <tbody>
      <% ingredients.forEach((item) => { %>
      <%
        const audited = Number(item.has_audit) === 1;
        const isLow = audited && item.quantity < item.min_stock;
      %>
      <tr class="<%= isLow ? 'low-stock' : '' %>">
        <td>
          <%= item.name %>
          <% if (isLow) { %>
            <span class="stock-flag" title="Bajo stock" aria-label="Advertencia de bajo stock"></span>
          <% } else if (!audited) { %>
            <span class="badge bg-secondary ms-1" title="Aún no registrado en auditorías">No auditado</span>
          <% } %>
        </td>
        <td><%= item.category_name %></td>
        <td class="unit-cell" data-base-unit="<%= item.unit %>" data-raw-value="<%= item.quantity %>"><span class="unit-value"><%= item.quantity %></span> <span class="unit-unit"><%= item.unit %></span></td>
        <td class="unit-cell" data-base-unit="<%= item.unit %>" data-raw-value="<%= item.min_stock %>"><span class="unit-value"><%= item.min_stock %></span> <span class="unit-unit"><%= item.unit %></span></td>
        <td>
          <form action="/admin/movimientos" method="POST" class="d-flex gap-2 flex-wrap">
            <input type="hidden" name="ingredient_id" value="<%= item.id %>" />
            <select class="form-select form-select-sm" name="type">
              <option value="entrada">Entrada</option>
              <option value="salida">Salida</option>
            </select>
            <input class="form-control form-control-sm" type="number" name="quantity" min="0.1" step="0.1" placeholder="Cantidad" required />
            <input class="form-control form-control-sm" type="text" name="note" placeholder="Nota" />
            <button class="btn btn-sm btn-success">Guardar</button>
          </form>
        </td>
        <td>
          <div class="d-flex gap-1">
            <a href="/admin/ingredientes/<%= item.id %>/editar" class="btn btn-sm btn-warning">Editar</a>
            <form action="/admin/ingredientes/<%= item.id %>/eliminar" method="POST" class="needs-confirm">
              <button class="btn btn-sm btn-danger" data-confirm="Eliminar ingrediente?">Eliminar</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
      <% if (!ingredients.length) { %><tr><td colspan="6">No hay ingredientes.</td></tr><% } %>
    </tbody>
  </table>
</div>
<%- include("../partials/footer") %>
