<%- include("../partials/header") %>
<% const supplierFilters = locals.filters || { search: '' }; %>
<% const supplierList = locals.suppliers || []; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Proveedores</h3>
  <a href="/admin/proveedores/nuevo" class="btn btn-primary">+ Nuevo Proveedor</a>
</div>

<div class="mb-3">
  <form method="GET" action="/admin/proveedores" class="d-flex gap-2">
    <input type="text" name="search" class="form-control" placeholder="Buscar por nombre, email o teléfono..." value="<%= supplierFilters.search || '' %>" />
    <button class="btn btn-secondary" type="submit">Buscar</button>
    <% if (supplierFilters.search) { %>
      <a href="/admin/proveedores" class="btn btn-outline-secondary">Limpiar</a>
    <% } %>
  </form>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>Nombre</th>
        <th>Contacto</th>
        <th>Teléfono</th>
        <th>Email</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (supplierList.length > 0) { %>
        <% supplierList.forEach(function(supplier) { %>
          <tr>
            <td><strong><%= supplier.name %></strong></td>
            <td><%= supplier.contact_info || '-' %></td>
            <td><%= supplier.phone || '-' %></td>
            <td><%= supplier.email || '-' %></td>
            <td>
              <div class="btn-group btn-group-sm" role="group">
                <a href="/admin/proveedores/<%= supplier.id %>/ingredientes" class="btn btn-info" title="Gestionar ingredientes">
                  Ingredientes
                </a>
                <a href="/admin/proveedores/<%= supplier.id %>/editar" class="btn btn-warning" title="Editar">
                  Editar
                </a>
                <form method="POST" action="/admin/proveedores/<%= supplier.id %>/eliminar" style="display: inline;" onsubmit="return confirm('¿Eliminar este proveedor?');">
                  <button type="submit" class="btn btn-danger" title="Eliminar">
                    Eliminar
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="5" class="text-center text-muted">No hay proveedores registrados.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/footer") %>
