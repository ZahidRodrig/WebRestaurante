    </main>

    <!-- Modales en la raíz del documento (evita bug de backdrop anidado) -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Confirmación</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
          </div>
          <div class="modal-body" id="confirmModalBody">¿Estás seguro?</div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" class="btn btn-danger" id="confirmModalOk">Confirmar</button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="categoriesModal" tabindex="-1" aria-labelledby="categoriesModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="categoriesModalLabel">Gestionar Categorías de Menú</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
          </div>
          <div class="modal-body">
            <div id="categoriesList" class="mb-3"></div>
            <div class="card">
              <div class="card-body">
                <h6 class="card-title">Agregar nueva categoría</h6>
                <div class="input-group">
                  <input type="text" id="newCategoryName" class="form-control" placeholder="Nombre de categoría" />
                  <button type="button" class="btn btn-success" id="addCategoryBtn">Agregar</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/ingredient-exclusion.js?v=<%= assetVersion %>"></script>
    <script src="/js/main.js?v=<%= assetVersion %>"></script>
  </body>
</html>
