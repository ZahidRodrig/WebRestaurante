<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Inventario Restaurante</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <a class="navbar-brand" href="/">Inventario Restaurante</a>
        <% if (user) { %>
        <div class="d-flex align-items-center gap-2">
          <span class="text-white small"><%= user.name %> (<%= user.role %>)</span>
          <form action="/logout" method="POST">
            <button class="btn btn-outline-light btn-sm" type="submit">Salir</button>
          </form>
        </div>
        <% } %>
      </div>
    </nav>
    <main class="container pb-4">
      <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
      <% } %>
