<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Inventario Restaurante</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="bg-light">
    <header class="app-header">
      <nav class="navbar navbar-dark bg-dark app-navbar">
        <div class="container d-flex align-items-center">
          <a class="navbar-brand me-2" href="/">Inventario Restaurante</a>
          <button class="btn btn-outline-light d-lg-none me-2" id="menu-toggle" aria-label="Mostrar menú">☰</button>
          <div class="ms-auto d-flex align-items-center gap-2">
            <% if (user) { %>
            <span class="text-white small d-none d-sm-inline"><%= user.name %> (<%= user.role %>)</span>
            <form action="/logout" method="POST" class="m-0">
              <button class="btn btn-outline-light btn-sm" type="submit">Salir</button>
            </form>
            <% } %>
          </div>
        </div>
      </nav>
      <% if (user) { %>
      <div class="app-subnav">
        <div class="container">
          <%- include("./menu") %>
        </div>
      </div>
      <% } %>
    </header>
    <main class="container pb-4 pt-3">
      <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %></div>
      <% } %>
      <% if (success) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert"><%= success %></div>
      <% } %>
