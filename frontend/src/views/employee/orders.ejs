<%- include("../partials/header") %>
<%- include("../partials/menu") %>

<h3>Mis Órdenes</h3>

<a href="/empleado/punto-de-venta" class="btn btn-primary mb-3">Nueva Orden</a>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>ID Orden</th>
        <th>Fecha</th>
        <th>Items</th>
        <th>Monto Total</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (orders && orders.length > 0) { %>
        <% orders.forEach(order => { %>
          <tr>
            <td>#<%= order.id %></td>
            <td><%= new Date(order.created_at).toLocaleString('es-ES') %></td>
            <td><span class="badge bg-info"><%= order.total_items %></span></td>
            <td><strong class="text-success">$<%= (order.total_amount || 0).toFixed(2) %></strong></td>
            <td>
              <a href="/empleado/ordenes/<%= order.id %>" class="btn btn-sm btn-info">
                Ver
              </a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="5" class="text-center text-muted">No tienes órdenes registradas.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("../partials/footer") %>
