<%- include("../partials/header") %>
<%- include("../partials/menu") %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Inventario</h3>
  <div class="d-flex gap-2 align-items-center">
    <select id="unit-system-select" class="form-select form-select-sm">
      <option value="metric">Métrico</option>
      <option value="imperial">Imperial</option>
    </select>
  </div>
</div>

<div class="table-responsive">
<table class="table table-bordered table-hover">
  <thead><tr><th>Ingrediente</th><th>Categoria</th><th>Stock Físico</th><th>Minimo</th><th>Movimiento</th></tr></thead>
  <tbody>
    <% ingredients.forEach((item) => { %>
    <tr class="<%= item.stock_physical < item.min_stock ? 'low-stock' : '' %>">
      <td>
        <%= item.name %>
        <% if (item.stock_physical < item.min_stock) { %>
        <span class="stock-flag" title="Bajo stock" aria-label="Advertencia de bajo stock"></span>
        <% } %>
      </td>
      <td><%= item.category_name %></td>
      <td class="unit-cell" data-base-unit="<%= item.base_unit %>" data-raw-value="<%= item.stock_physical %>"><span class="unit-value"><%= item.stock_physical.toFixed(2) %></span> <span class="unit-unit"><%= item.base_unit %></span></td>
      <td class="unit-cell" data-base-unit="<%= item.base_unit %>" data-raw-value="<%= item.min_stock %>"><span class="unit-value"><%= item.min_stock.toFixed(2) %></span> <span class="unit-unit"><%= item.base_unit %></span></td>
      <td>
        <form action="/empleado/movimiento" method="POST" class="d-flex gap-2 flex-wrap">
          <input type="hidden" name="ingredient_id" value="<%= item.id %>" />
          <select class="form-select form-select-sm" name="type" required>
            <option value="salida">Salida</option>
            <option value="entrada">Entrada</option>
          </select>
          <input class="form-control form-control-sm" type="number" name="quantity" min="0.1" step="0.1" placeholder="Cantidad" required />
          <input class="form-control form-control-sm" type="text" name="note" placeholder="Nota" />
          <button class="btn btn-sm btn-primary">Registrar</button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
</div>
<%- include("../partials/footer") %>
