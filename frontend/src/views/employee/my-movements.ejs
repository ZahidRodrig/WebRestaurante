<%- include("../partials/header") %>
<%- include("../partials/menu") %>
<h3>Mis movimientos</h3>
<p class="text-muted mb-2">Indicadores: <span class="status-pill status-pill-entrada">E + ENTRADA</span> <span class="status-pill status-pill-salida">S - SALIDA</span></p>
<table class="table table-striped table-bordered">
  <thead><tr><th>Fecha</th><th>Tipo</th><th>Ingrediente</th><th>Cantidad</th><th>Nota</th></tr></thead>
  <tbody>
    <% movements.forEach((m) => { %>
    <tr>
      <td><%= new Date(m.created_at).toLocaleString("es-MX") %></td>
      <td>
        <span class="status-pill <%= m.type === 'entrada' ? 'status-pill-entrada' : 'status-pill-salida' %>">
          <%= m.type === "entrada" ? "E +" : "S -" %> <%= m.type.toUpperCase() %>
        </span>
      </td>
      <td><%= m.ingredient_name %></td>
      <td><%= m.quantity %> <%= m.ingredient_unit %></td>
      <td><%= m.note || "-" %></td>
    </tr>
    <% }) %>
  </tbody>
</table>
<%- include("../partials/footer") %>
